{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "three": ["node_modules/three/build/three.module.d.ts"],
      "three/addons/*": ["node_modules/three/examples/jsm/*"]
    }
  },
  "include": [
    "src/editor/ShortcutManager.js",
    "src/editor/EntityFactory.js",
    "src/editor/UndoManager.js",
    "src/editor/commands/*.js",
    "src/engine/Component.js",
    "src/engine/Entity.js",
    "src/engine/Scene.js"
  ],
  "exclude": ["node_modules", "dist"]
}
